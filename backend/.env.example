PORT=5000
JWT_SECRET=change_this_to_a_random_secret
ADMIN_EMAIL=admin@aura.store
ADMIN_PASSWORD=Admin@1234

# MongoDB Atlas connection string (get from atlas.mongodb.com)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aura?retryWrites=true&w=majority

# Your frontend URL (Vercel URL after deploy)
FRONTEND_URL=https://your-store.vercel.app

# Email (optional)
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
